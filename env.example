# Neon PostgreSQL Database Connection String
# Get this from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxxxxxx.us-east-1.neon.tech/neon?sslmode=require

# JWT Secret for authentication tokens
# Change this to a strong random string in production
JWT_SECRET=your-super-secret-key-change-in-production-12345

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS - only needed for backend server)
FRONTEND_URL=http://localhost:3000
